# ── Secrets & credentials ─────────────────────────────────────────
.env
*.pem
*.key
*.crt
mkcert

# ── Python ────────────────────────────────────────────────────────
venv/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
*.so

# ── Logs & runtime data ───────────────────────────────────────────
*.log
audit_log.json
audit_log.json*
handoff_log.json

# ── Databases (users, audit log — NEVER push to GitHub) ──────────
aria.db
*.sqlite
*.sqlite3

# ── Certs (also covered by *.pem above; explicit per backup spec) ─
aria-cert.pem
aria-key.pem

# ── Node / JS build artifacts (keep automated backups lean) ──────
node_modules/

# ── User data (contains hashed passwords) ────────────────────────
config/users.json

# ── macOS ─────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Editor ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Broken/backup server files ────────────────────────────────────
aria_server_broken.py
aria_server_clean.py
aria_server_github.py

# ── LaunchAgent plist (machine-specific) ─────────────────────────
com.trsd.aria.plist
