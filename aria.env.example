# ARIA Backend Configuration
# Fill in your values below, then save as .env (no .example)
# NEVER share this file — it contains credentials.

# Your Jamf Pro URL (no trailing slash)
JAMF_URL=https://trsd.jamfcloud.com

# Jamf API Role credentials (Settings > System > API Roles and Clients)
JAMF_CLIENT_ID=your-api-client-id-here
JAMF_CLIENT_SECRET=your-api-client-secret-here

# Secret key the UI sends with every request. Generate one:
# python3 -c "import secrets; print(secrets.token_hex(24))"
ARIA_API_KEY=changeme-generate-a-real-key

# Port (default 5001)
ARIA_PORT=5001
