# Jamf Pro credentials
JAMF_URL=https://yourschool.jamfcloud.com
JAMF_CLIENT_ID=your-jamf-api-client-id
JAMF_CLIENT_SECRET=your-jamf-api-client-secret

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ARIA settings
ARIA_PORT=5001
# Generate a strong random string: python3 -c "import secrets; print(secrets.token_hex(24))"
ARIA_API_KEY=change-this-to-a-random-string

# Your organization name (shown in the UI header)
ORG_NAME=Your Organization

# Comma-separated list of tech names for the session login dropdown
TECH_NAMES=Alice,Bob,Carol,Dave

# Optional: Slack webhook URL for session escalation notifications
SLACK_WEBHOOK_URL=
